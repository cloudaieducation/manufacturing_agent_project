# ============================================================
# 삼성디스플레이 재직자 대상 AI Agent Architecture 실습
# .env.example
# ============================================================
#
# 이 파일은 GitHub에 올릴 수 있는 환경변수 "예시" 파일입니다.
# 실제 API Key, 사내 데이터, 제조 데이터, 개인정보, 민감정보는
# 절대 이 파일에 작성하지 마세요. (Key처럼 보이는 임의 문자열도 넣지 않습니다.)
#
# 사용 방법:
# 1. 이 파일을 복사해 .env 파일을 만듭니다.
#      Windows PowerShell : Copy-Item .env.example .env
#      macOS/Linux        : cp .env.example .env
# 2. 기본값(mock)으로는 API Key 없이 바로 실습할 수 있습니다.
# 3. Cloud LLM을 쓰려면 LLM_PROVIDER=cloud로 바꾸고, 해당 Provider의 API Key를
#    .env 파일에만 입력합니다.
#
# 보안 주의:
# - API Key는 비밀번호처럼 관리합니다. 화면 공유/캡처/강의자료/GitHub에 노출하지 마세요.
# - .gitignore에 .env 와 .env.* 가 포함되어 있고, .env.example만 예외로 커밋됩니다.
# ============================================================


# ------------------------------------------------------------
# 1. 전체 LLM 실행 방식 선택
# ------------------------------------------------------------
# 가능한 값:
# - mock  : API Key 없이 교육용 Mock LLM을 사용합니다. (기본값)
# - local : Ollama 기반 Local LLM을 사용합니다.
# - cloud : Gemini, OpenAI, Anthropic, NVIDIA 같은 Cloud LLM을 사용합니다.
#
# 수강생이 API Key 없이 바로 실습할 수 있도록 예시 기본값은 mock으로 둡니다.
# 강사/실습 환경에서 NVIDIA 등 Cloud LLM을 쓰려면 cloud로 변경하세요.
LLM_PROVIDER=mock


# ------------------------------------------------------------
# 2. Cloud LLM Provider 선택
# ------------------------------------------------------------
# LLM_PROVIDER=cloud일 때 어떤 Provider를 사용할지 선택합니다.
# 가능한 값: nvidia, gemini, openai, anthropic
# mistral-nemotron 등 NVIDIA API Catalog 모델 사용 시 nvidia로 설정합니다.
CLOUD_LLM_PROVIDER=nvidia


# ------------------------------------------------------------
# 3. NVIDIA API Catalog / NIM 설정
# ------------------------------------------------------------
# 사용 조건: LLM_PROVIDER=cloud, CLOUD_LLM_PROVIDER=nvidia
# 실제 NVIDIA API Key는 복사본 .env 파일에만 입력하세요. (여기에는 비워 둡니다.)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# 예: stepfun-ai/step-3.5-flash, mistralai/mistral-nemotron 등 NVIDIA 카탈로그 모델명
NVIDIA_MODEL_NAME=stepfun-ai/step-3.5-flash

# NVIDIA 호출용 system prompt입니다. 필요하면 수업 목적에 맞게 조정합니다.
NVIDIA_SYSTEM_PROMPT=너는 제조 장애 대응 AI Agent다. 사용자가 요구한 출력 형식을 정확히 따르고, 제공된 근거 안에서만 판단한다. 근거 없는 원인 단정, 실제 사내 시스템 접근, 민감정보 노출은 하지 않는다. 응답은 한국어로 작성한다.


# ------------------------------------------------------------
# 4. 다른 Cloud Provider 설정 - 선택 사항
# ------------------------------------------------------------
# 사용하려는 Provider의 Key만 복사본 .env에 입력하세요. (여기에는 비워 둡니다.)
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_NAME=claude-3-5-haiku-latest


# ------------------------------------------------------------
# 5. Local LLM 설정 - 선택 사항 (Ollama)
# ------------------------------------------------------------
# 사용 조건: LLM_PROVIDER=local
# 미리 모델을 받아 두세요. 예: ollama pull qwen2.5:1.5b
LOCAL_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=qwen2.5:1.5b
# JSON 응답을 강제하고 싶을 때 json으로 둡니다. (Tool Plan 실습 등)
OLLAMA_RESPONSE_FORMAT=json


# ------------------------------------------------------------
# 6. 공통 LLM 생성 옵션
# ------------------------------------------------------------
# temperature는 응답의 일관성을 조절합니다. (낮을수록 안정적)
# Tool Plan JSON 안정성을 최우선으로 할 때는 0.0~0.2를 권장합니다.
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.7
# max output tokens가 너무 작으면 리포트가 중간에 끊길 수 있습니다.
LLM_MAX_OUTPUT_TOKENS=4096


# ------------------------------------------------------------
# 7. 프로젝트 기본 설정
# ------------------------------------------------------------
PROJECT_NAME=manufacturing-agent
APP_ENV=education
# 실행 결과 저장 폴더입니다. outputs/ 는 .gitignore 대상입니다.
OUTPUT_DIR=outputs
LOG_LEVEL=INFO


# ------------------------------------------------------------
# 8. PostgreSQL 설정 - 교육용 Docker DB
# ------------------------------------------------------------
# db/docker-compose.yml 로 띄우는 교육용 DB 접속 정보입니다.
# 실제 운영 비밀번호가 아닌 교육용 기본값입니다.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=manufacturing_agent_db
POSTGRES_USER=agent_user
POSTGRES_PASSWORD=agent_password


# ------------------------------------------------------------
# 9. Day4 LLM Tool Selection 설정
# ------------------------------------------------------------
# Tool 선택 방식: rule_based(규칙 기반) / llm_based(LLM 기반)
TOOL_SELECTOR_MODE=rule_based
# LLM Tool Plan을 실제 Tool 호출까지 실행할지 여부 (교육 안정성을 위해 기본 false)
DAY4_EXECUTE_LLM_TOOL_PLAN=false
# LLM Tool Plan 파싱 실패 시 규칙 기반으로 전환할지 여부
DAY4_TOOL_SELECTION_FALLBACK=true
# Tool Plan 생성용 temperature는 낮게 둡니다.
DAY4_TOOL_SELECTION_TEMPERATURE=0.0
# Tool Plan 결과 저장 위치
DAY4_OUTPUT_DIR=outputs/day4
# Tool Plan을 실행하지 않고 검증만 수행할지 여부
DAY4_TOOL_PLAN_VALIDATE_ONLY=true
# 처리할 최대 테스트 케이스 수
DAY4_TOOL_SELECTION_MAX_CASES=100
# LLM 응답에서 JSON 추출 실패 시 추가 fallback 사용 여부
DAY4_JSON_EXTRACTION_FALLBACK=true


# ------------------------------------------------------------
# 10. Cloud LLM 진단 로그 설정
# ------------------------------------------------------------
# Cloud LLM 호출의 request/response/error를 JSONL로 남길지 여부입니다.
# (API Key, Bearer 토큰 등 민감정보는 기록하지 않습니다.)
CLOUD_LLM_DIAGNOSTICS_ENABLED=true
# 진단 로그 저장 위치 (outputs/ 는 .gitignore 대상)
CLOUD_LLM_DIAGNOSTICS_LOG_PATH=outputs/llm/cloud_llm_diagnostics.jsonl
# 진단 수준: basic / verbose
CLOUD_LLM_DIAGNOSTICS_LEVEL=verbose
# prompt/response 미리보기 최대 길이
CLOUD_LLM_DIAGNOSTICS_PREVIEW_CHARS=4096
# prompt 일부를 로그에 남길지 여부 (보안상 기본 false 권장)
CLOUD_LLM_DIAGNOSTICS_INCLUDE_PROMPT=false
# raw response 일부를 로그에 남길지 여부 (문제 분석 중에만 true 권장)
CLOUD_LLM_DIAGNOSTICS_INCLUDE_RAW_RESPONSE=false
# choices를 몇 개까지 진단할지
CLOUD_LLM_DIAGNOSTICS_MAX_CHOICES=100

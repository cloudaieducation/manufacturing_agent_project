# ============================================================
# 삼성디스플레이 재직자 대상 AI Agent Architecture 1일차 실습
# .env.example
# ============================================================
#
# 이 파일은 GitHub에 올릴 수 있는 환경변수 예시 파일입니다.
# 실제 API Key, 사내 데이터, 제조 데이터, 개인정보, 민감정보는
# 절대 이 파일에 작성하지 마세요.
#
# 이 파일에는 API Key처럼 보이는 예시 문자열도 넣지 않습니다.
# 실제 API Key는 반드시 .env.example을 복사한 .env 파일에만 입력합니다.
#
# 사용 방법:
# 1. 이 파일을 복사해서 .env 파일을 만듭니다.
# 2. 수강생은 기본값인 mock LLM으로 API Key 없이 바로 실습할 수 있습니다.
# 3. Local LLM을 사용할 경우 LLM_PROVIDER를 local로 바꾸고 Ollama 설정을 확인합니다.
# 4. Cloud LLM을 사용할 경우 LLM_PROVIDER를 cloud로 바꾸고 CLOUD_LLM_PROVIDER를 선택합니다.
# 5. 실제 API Key는 .env 파일에만 입력하고, .env 파일은 GitHub에 올리지 않습니다.
#
# 예시:
# Windows PowerShell:
#   Copy-Item .env.example .env
#
# macOS/Linux:
#   cp .env.example .env
#
# 보안 주의:
# - API Key는 비밀번호처럼 관리해야 합니다.
# - 화면 공유, 캡처, 강의자료, GitHub commit에 API Key가 포함되지 않도록 주의하세요.
# - .gitignore에 .env와 .env.*가 포함되어 있어야 합니다.
# - 단, .env.example은 Git에 올라가야 하므로 .gitignore에서 예외 처리할 수 있습니다.
# - .env.example에는 실제 Key뿐 아니라 Key처럼 보이는 임의 문자열도 작성하지 않습니다.
# ============================================================


# ------------------------------------------------------------
# 1. 전체 LLM 실행 방식 선택
# ------------------------------------------------------------
# Agent가 사용할 LLM 실행 방식을 선택합니다.
#
# 가능한 값:
# - mock  : API Key 없이 교육용 mock LLM을 사용합니다.
# - local : 수강생 PC에 설치한 Ollama 로컬 LLM을 사용합니다.
# - cloud : Gemini, OpenAI API, Anthropic API 같은 Cloud LLM을 사용합니다.
#
# 기본값은 반드시 mock입니다.
# 수강생이 API Key 없이 바로 실습할 수 있도록 기본값을 mock으로 둡니다.
LLM_PROVIDER=mock


# ------------------------------------------------------------
# 2. Mock LLM 설정
# ------------------------------------------------------------
# mock LLM은 실제 외부 LLM을 호출하지 않는 교육용 응답 생성 방식입니다.
#
# 특징:
# - API Key가 필요 없습니다.
# - 인터넷 연결이나 유료 API 없이 실습할 수 있습니다.
# - LLM 호출 구조, Prompt 구성, Chain 흐름, Agent 실행 구조를 먼저 이해하는 데 사용합니다.
#
# 별도 설정값은 필요하지 않습니다.
# LLM_PROVIDER=mock이면 mock LLM을 사용합니다.


# ------------------------------------------------------------
# 3. Local LLM 설정 - Ollama
# ------------------------------------------------------------
# local LLM은 수강생 PC에서 Ollama를 실행한 뒤 사용하는 방식입니다.
#
# 사용 방법:
# 1. Ollama를 설치합니다.
# 2. 사용할 모델을 미리 다운로드합니다.
#    예: ollama pull phi3:mini
#    예: ollama pull llama3.1:8b
# 3. .env 파일에서 LLM_PROVIDER=local로 변경합니다.
# 4. OLLAMA_MODEL_NAME 값만 바꿔 사용할 모델을 선택합니다.
#
# 권장 기본 모델:
# - phi3:mini : 상대적으로 가볍고 수강생 PC 부담이 적은 모델입니다.
# - llama3.1:8b : 성능은 더 좋을 수 있으나 PC 사양과 디스크 용량 부담이 더 큽니다.
LOCAL_LLM_PROVIDER=ollama

# Ollama 기본 실행 주소입니다.
# 일반적으로 Ollama 설치 후 기본값은 아래 주소를 사용합니다.
OLLAMA_BASE_URL=http://localhost:11434

# 사용할 Ollama 모델명입니다.
# 가능한 값 예:
# - phi3:mini
# - llama3.1:8b
OLLAMA_MODEL_NAME=phi3:mini


# ------------------------------------------------------------
# 4. Cloud LLM Provider 선택
# ------------------------------------------------------------
# Cloud LLM을 사용할 때 어떤 Provider를 사용할지 선택합니다.
#
# 사용 방법:
# 1. LLM_PROVIDER=cloud로 변경합니다.
# 2. CLOUD_LLM_PROVIDER 값을 gemini, openai, anthropic 중 하나로 변경합니다.
# 3. 선택한 Provider에 해당하는 API Key만 .env 파일에 입력합니다.
#
# 가능한 값:
# - gemini    : Google Gemini API를 사용합니다.
# - openai    : OpenAI API를 사용합니다.
# - anthropic : Anthropic API를 사용합니다.
CLOUD_LLM_PROVIDER=gemini


# ------------------------------------------------------------
# 5. Gemini 설정
# ------------------------------------------------------------
# Gemini를 사용할 때 필요한 설정입니다.
#
# 사용 조건:
# - LLM_PROVIDER=cloud
# - CLOUD_LLM_PROVIDER=gemini
#
# 실제 Gemini API Key는 .env 파일에만 입력하세요.
# .env.example에는 실제 Key나 Key처럼 보이는 예시 문자열을 넣지 않습니다.
GEMINI_API_KEY=

# Gemini 모델명입니다.
# 수업 시점의 지원 모델이나 정책에 따라 변경될 수 있습니다.
GEMINI_MODEL_NAME=gemini-2.0-flash


# ------------------------------------------------------------
# 6. OpenAI 설정
# ------------------------------------------------------------
# OpenAI API를 사용할 때 필요한 설정입니다.
#
# 사용 조건:
# - LLM_PROVIDER=cloud
# - CLOUD_LLM_PROVIDER=openai
#
# 실제 OpenAI API Key는 .env 파일에만 입력하세요.
# .env.example에는 실제 Key나 Key처럼 보이는 예시 문자열을 넣지 않습니다.
OPENAI_API_KEY=

# OpenAI 모델명입니다.
# 수업 시점의 지원 모델이나 정책에 따라 변경될 수 있습니다.
OPENAI_MODEL_NAME=gpt-4o-mini


# ------------------------------------------------------------
# 7. Anthropic 설정
# ------------------------------------------------------------
# Anthropic API를 사용할 때 필요한 설정입니다.
#
# 사용 조건:
# - LLM_PROVIDER=cloud
# - CLOUD_LLM_PROVIDER=anthropic
#
# 실제 Anthropic API Key는 .env 파일에만 입력하세요.
# .env.example에는 실제 Key나 Key처럼 보이는 예시 문자열을 넣지 않습니다.
ANTHROPIC_API_KEY=

# Anthropic 모델명입니다.
# 수업 시점의 지원 모델이나 정책에 따라 변경될 수 있습니다.
ANTHROPIC_MODEL_NAME=claude-3-5-haiku-latest


# ------------------------------------------------------------
# 8. 공통 LLM 생성 옵션
# ------------------------------------------------------------
# 아래 설정은 mock, local, cloud 방식에서 공통으로 참고할 수 있는 LLM 생성 옵션입니다.
# 단, 실제 적용 여부는 각 LLM 호출 코드 구현 방식에 따라 달라질 수 있습니다.
#
# temperature는 응답의 창의성 정도를 조절합니다.
# 낮을수록 더 안정적이고 일관된 답변을 기대할 수 있습니다.
LLM_TEMPERATURE=0.2

# max output tokens는 LLM 응답의 최대 길이를 조절합니다.
# 값이 너무 작으면 리포트나 설명이 중간에 끊길 수 있습니다.
LLM_MAX_OUTPUT_TOKENS=2048


# ------------------------------------------------------------
# 9. 프로젝트 기본 설정
# ------------------------------------------------------------
# 교육용 프로젝트 이름입니다.
PROJECT_NAME=manufacturing-agent-day1

# 실행 환경 구분입니다.
# 이 실습에서는 education으로 둡니다.
APP_ENV=education

# 실행 결과 저장 폴더입니다.
# outputs/ 폴더는 .gitignore에 포함되어 GitHub에 올라가지 않도록 관리합니다.
OUTPUT_DIR=outputs

# 로그 출력 수준입니다.
# 일반 실습에서는 INFO를 사용합니다.
LOG_LEVEL=INFO

# ==========================================
# 10.PostgreSQL 설정
# ==========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=manufacturing_agent_db
POSTGRES_USER=agent_user
POSTGRES_PASSWORD=agent_password

# ------------------------------------------------------------
#11. LLM Tool Selection 설정
# ------------------------------------------------------------
# Tool 선택 방식:
# - rule_based : 규칙 기반 Tool 선택
# - llm_based  : LLM 기반 Tool 선택
TOOL_SELECTOR_MODE=rule_based

# 4일차에서 LLM Tool Plan을 실제 Tool 호출까지 실행할지 여부
# 교육 안정성을 위해 기본값은 false입니다.
DAY4_EXECUTE_LLM_TOOL_PLAN=false

# LLM Tool Plan JSON 파싱 실패 시 규칙 기반 Tool Plan으로 전환할지 여부
DAY4_TOOL_SELECTION_FALLBACK=true

# Tool Plan 생성용 온도는 낮게 둡니다.
DAY4_TOOL_SELECTION_TEMPERATURE=0.0

# Tool Plan 결과 저장 위치
DAY4_OUTPUT_DIR=outputs/day4

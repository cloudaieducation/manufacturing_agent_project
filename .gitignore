# ============================================================
# AI Agent Architecture Training Project
# Git ignore rules
# ============================================================

# ------------------------------------------------------------
# 1. API Keys / Environment variables
# ------------------------------------------------------------
.env
.env.*
!.env.example

# ------------------------------------------------------------
# 2. Python cache files
# ------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/

# ------------------------------------------------------------
# 3. Virtual environments
# ------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ------------------------------------------------------------
# 4. Jupyter Notebook
# ------------------------------------------------------------
#.ipynb_checkpoints/

# ------------------------------------------------------------
# 5. Execution outputs and logs
# ------------------------------------------------------------
#outputs/
logs/
*.log

# ------------------------------------------------------------
# 6. Temporary files
# ------------------------------------------------------------
tmp/
temp/
*.tmp

# ------------------------------------------------------------
# 7. OS files
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# 8. IDE settings
# ------------------------------------------------------------
.vscode/
.idea/

# ------------------------------------------------------------
# 9. Build / distribution files
# ------------------------------------------------------------
build/
dist/
*.egg-info/
# ------------------------------------------------------------
# 10. Office temporary files
# ------------------------------------------------------------
~$*
*.bak
*.old
# ------------------------------------------------------------
# 11. Archive files
# ------------------------------------------------------------
*.zip
*.7z
*.rar
# ------------------------------------------------------------
# 12. AI / Vector DB / Local DB artifacts
# ------------------------------------------------------------
*.pt
*.pth
*.ckpt
*.onnx
*.pkl
*.pickle

chroma/
chroma_db/
vector_db/